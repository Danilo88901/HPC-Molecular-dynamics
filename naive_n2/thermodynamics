double kinetic_energy(int n, double m, double* vx, double* vy, double* vz) {
	double K = 0.0;
	for (int i = 0; i < n; i++) {
		K += 0.5 * m * (vx[i] * vx[i] + vy[i] * vy[i] + vz[i] * vz[i]);
	}
	return K;
}
double temperature(int n, double m, double* vx, double* vy, double* vz) {
	double K = kinetic_energy(n, m, vx, vy, vz);
	int f = 3 * n - 3;
	return 2 * K / (f * kb);
}
