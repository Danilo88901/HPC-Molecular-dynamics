#include <iostream>
#include <random>
double kb = 1.380649e-23;
double sigma = 3.405e-10;
double epsilon = 1.654e-21;
double m = 6.6335e-26;
double r_cut2 = (2.5 * sigma) * (2.5 * sigma);
double invr2 = sigma * sigma / r_cut2;
double invr6 = invr2 * invr2 * invr2;
double invr12 = invr6 * invr6;
double U_shift = 4 * epsilon * (invr12 - invr6);
double T = 80.0;
double M_PI = 3.1415926535;
double v_std = sqrt(kb * T / m);
double Lennard_Jones(int n, double sigma, double epsilon, double m, double r_cut2,
	double U_shift, double L, double* x,
	double* y, double* z, double* fx, double* fy, double* fz) {
	for (int i = 0; i < n; i++) {
		fx[i] = 0.0;
		fy[i] = 0.0;
		fz[i] = 0.0;
	}
	double U_total = 0.0;
	for (int i = 0; i < n; i++) {
		for (int j = i + 1; j < n; j++) {
			double dx = x[j] - x[i];
			dx -= L * nearbyint(dx / L);
			double dy = y[j] - y[i];
			dy -= L * nearbyint(dy / L);
			double dz = z[j] - z[i];
			dz -= L * nearbyint(dz / L);
			double r2 = dx * dx + dy * dy + dz * dz;
			if (r2 > r_cut2)continue;
			double inv_r2 = sigma * sigma / r2;
			double inv_r6 = inv_r2 * inv_r2 * inv_r2;
			double inv_r12 = inv_r6 * inv_r6;

			U_total += 4 * epsilon * (inv_r12 - inv_r6) - U_shift;
			double F_scalar = 24 * epsilon * (2 * inv_r12 - inv_r6) / r2;
			double fxx = -F_scalar * dx;
			double fyy = -F_scalar * dy;
			double fzz = -F_scalar * dz;
			fx[i] += fxx;
			fy[i] += fyy;
			fz[i] += fzz;

			fx[j] -= fxx;
			fy[j] -= fyy;
			fz[j] -= fzz;


		}
	}
	return U_total;
}
double integrate(int n, double sigma, double epsilon, double m, double dt, double r_cut2,
	double U_shift, double L, double* x,
	double* y, double* z, double* fx, double* fy, double* fz,
	double* vx, double* vy, double* vz, double* fx_old, double* fy_old, double* fz_old) {
	for (int i = 0; i < n; i++) {
		fx_old[i] = fx[i];
		fy_old[i] = fy[i];
		fz_old[i] = fz[i];
	}

	for (int i = 0; i < n; i++) {
		x[i] += dt * vx[i] + 0.5 * fx[i] / m * dt * dt;
		x[i] -= L * round(x[i] / L);

		y[i] += dt * vy[i] + 0.5 * fy[i] / m * dt * dt;
		y[i] -= L * round(y[i] / L);

		z[i] += dt * vz[i] + 0.5 * fz[i] / m * dt * dt;
		z[i] -= L * round(z[i] / L);
	}
	double U = Lennard_Jones(n, sigma, epsilon, m, r_cut2, U_shift, L, x, y, z, fx, fy, fz);

	for (int i = 0; i < n; i++) {
		vx[i] += 0.5 * (fx[i] + fx_old[i]) / m * dt;
		vy[i] += 0.5 * (fy[i] + fy_old[i]) / m * dt;
		vz[i] += 0.5 * (fz[i] + fz_old[i]) / m * dt;
	}
	return U;
}
double kinetic_energy(int n, double m, double* vx, double* vy, double* vz) {
	double K = 0.0;
	for (int i = 0; i < n; i++) {
		K += 0.5 * m * (vx[i] * vx[i] + vy[i] * vy[i] + vz[i] * vz[i]);
	}
	return K;
}
double temperature(int n, double m, double* vx, double* vy, double* vz) {
	double K = kinetic_energy(n, m, vx, vy, vz);
	int f = 3 * n - 3;
	return 2 * K / (f * kb);
}
void init_velocities(int n, double* vx, double* vy, double* vz, std::mt19937& gen,
	double v_std) {
	std::normal_distribution<double>dist(0.0, v_std);
	for (int i = 0; i < n; i++) {
		vx[i] = dist(gen);
		vy[i] = dist(gen);
		vz[i] = dist(gen);
	}
	double vx_sum = 0.0;
	double vy_sum = 0.0;
	double vz_sum = 0.0;
	for (int i = 0; i < n; i++) {
		vx_sum += vx[i];
		vy_sum += vy[i];
		vz_sum += vz[i];
	}
	vx_sum /= n;
	vy_sum /= n;
	vz_sum /= n;
	for (int i = 0; i < n; i++) {
		vx[i] -= vx_sum;
		vy[i] -= vy_sum;
		vz[i] -= vz_sum;
	}
}
double init_positions(int n,
	double* x, double* y, double* z,
	double density,
	double mass)
{
	// сколько атомов по ребру
	int n_side = std::ceil(std::cbrt(n));

	// общий объём системы из плотности
	double V = (n * mass) / density;

	// длина кубической коробки
	double L = std::cbrt(V);

	// решётка внутри коробки
	double spacing = L / n_side;

	int count = 0;
	for (int i = 0; i < n_side; i++) {
		for (int j = 0; j < n_side; j++) {
			for (int k = 0; k < n_side; k++) {
				if (count < n) {
					x[count] = i * spacing;
					y[count] = j * spacing;
					z[count] = k * spacing;
					count++;
				}
			}
		}
	}

	return L;
}
