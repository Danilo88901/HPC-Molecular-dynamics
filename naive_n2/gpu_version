_device__ double atomicAddDouble(double* address, double val) {
	unsigned long long int* address_as_ull =
		(unsigned long long int*)address;

	unsigned long long int old = *address_as_ull;
	unsigned long long int assumed;

	do {
		assumed = old;
		double new_val = __longlong_as_double(assumed) + val;
		old = atomicCAS(address_as_ull,
			assumed,
			__double_as_longlong(new_val));
	} while (assumed != old);

	return __longlong_as_double(old);
}







__global__ void gpu_Leonard_Jones(int n, double sigma, double epsilon, double m, double r_cut2,
	double U_shift, double L, double* x,
	double* y, double* z, double* fx, double* fy, double* fz,
	double* U) {
	int i = blockDim.x * blockIdx.x + threadIdx.x;
	if (i >= n)return;
	fx[i] = 0.0;
	fy[i] = 0.0;
	fz[i] = 0.0;
	double x_main = x[i];
	double y_main = y[i];
	double z_main = z[i];
	double U_main = 0.0;
	for (int j = 0; j < n; j++) {
		if (i == j)continue;
		double dx = x[j] - x_main;
		dx -= L * nearbyint(dx / L);
		double dy = y[j] - y_main;
		dy -= L * nearbyint(dy / L);
		double dz = z[j] - z_main;
		dz -= L * nearbyint(dz / L);
		double r2 = dx * dx + dy * dy + dz * dz;
		if (r2 > r_cut2)continue;
		double inv_r2 = sigma * sigma / r2;
		double inv_r6 = inv_r2 * inv_r2 * inv_r2;
		double inv_r12 = inv_r6 * inv_r6;

		U_main += 4 * epsilon * (inv_r12 - inv_r6) - U_shift;
		double F_scalar = 24 * epsilon * (2 * inv_r12 - inv_r6) / r2;
		double fxx = -F_scalar * dx;
		double fyy = -F_scalar * dy;
		double fzz = -F_scalar * dz;
		fx[i] += fxx;
		fy[i] += fyy;
		fz[i] += fzz;
	}
	//U[i] = U_main;
	atomicAddDouble(&U[0], 0.5 * U_main);
}

__global__ void integrate_coordinates(int n, double m, double L, double dt, double* x, double* y, double* z,
	double* vx, double* vy, double* vz, double* fx,
	double* fy, double* fz, double* fx_old, double* fy_old, double* fz_old) {
	//1 step
	int i = blockDim.x * blockIdx.x + threadIdx.x;
	if (i >= n)return;
	fx_old[i] = fx[i];
	fy_old[i] = fy[i];
	fz_old[i] = fz[i];
	//2 step
	x[i] += dt * vx[i] + 0.5 * fx[i] / m * dt * dt;
	x[i] -= L * nearbyint(x[i] / L);

	y[i] += dt * vy[i] + 0.5 * fy[i] / m * dt * dt;
	y[i] -= L * nearbyint(y[i] / L);

	z[i] += dt * vz[i] + 0.5 * fz[i] / m * dt * dt;
	z[i] -= L * nearbyint(z[i] / L);


}
__global__ void integrate_velocities(int n, double m, double L, double dt,
	double* vx, double* vy, double* vz, double* fx,
	double* fy, double* fz, double* fx_old, double* fy_old, double* fz_old) {
	int i = blockDim.x * blockIdx.x + threadIdx.x;
	if (i >= n)return;
	vx[i] += 0.5 * (fx[i] + fx_old[i]) / m * dt;
	vy[i] += 0.5 * (fy[i] + fy_old[i]) / m * dt;
	vz[i] += 0.5 * (fz[i] + fz_old[i]) / m * dt;
}
void gpu_version() {
	std::mt19937 gen(42); 
	int size = n * sizeof(double);
	double* x = (double*)malloc(size);
	double* y = (double*)malloc(size);
	double* z = (double*)malloc(size);
	double density = 1400.0;//кг/м3
	double L = init_positions(n, x, y, z, density, m);
	double* vx = (double*)malloc(size);
	double* vy = (double*)malloc(size);
	double* vz = (double*)malloc(size);
	init_velocities(n, vx, vy, vz, gen,v_std);
	double* d_x, * d_y, * d_z, * d_vx, * d_vy, * d_vz;
	cudaMalloc(&d_x, size);
	cudaMalloc(&d_y, size);
	cudaMalloc(&d_z, size);
	cudaMalloc(&d_vx, size);
	cudaMalloc(&d_vy, size);
	cudaMalloc(&d_vz, size);

	cudaMemcpy(d_x, x, size, cudaMemcpyHostToDevice);
	cudaMemcpy(d_y, y, size, cudaMemcpyHostToDevice);
	cudaMemcpy(d_z, z, size, cudaMemcpyHostToDevice);

	cudaMemcpy(d_vx, vx, size, cudaMemcpyHostToDevice);
	cudaMemcpy(d_vy, vy, size, cudaMemcpyHostToDevice);
	cudaMemcpy(d_vz, vz, size, cudaMemcpyHostToDevice);
	double* d_fx, * d_fy, * d_fz, * d_fx_old, * d_fy_old, * d_fz_old;
	cudaMalloc(&d_fx, size);
	cudaMalloc(&d_fy, size);
	cudaMalloc(&d_fz, size);
	cudaMalloc(&d_fx_old, size);
	cudaMalloc(&d_fy_old, size);
	cudaMalloc(&d_fz_old, size);

	cudaMemset(d_fx, 0, size);
	cudaMemset(d_fy, 0, size);
	cudaMemset(d_fz, 0, size);

	cudaMemset(d_fx_old, 0, size);
	cudaMemset(d_fy_old, 0, size);
	cudaMemset(d_fz_old, 0, size);

	double* d_U;
	cudaMalloc(&d_U, sizeof(double));
	cudaMemset(d_U, 0, sizeof(double));
	int block_size = 256;
	int grid_size = (n + block_size - 1) / block_size;
	double U = 0.0;

	gpu_Leonard_Jones << <grid_size, block_size >> > (n, sigma, epsilon, m, r_cut2, U_shift, L, d_x, d_y, d_z,
		d_fx, d_fy, d_fz, d_U);
	cudaDeviceSynchronize(); // очистить очередь


	for (int i = 0; i < steps; i++) {
		cudaMemset(d_U, 0, sizeof(double));
		integrate_coordinates << <grid_size, block_size >> > (n, m, L, dt, d_x, d_y, d_z, d_vx, d_vy, d_vz,
			d_fx, d_fy, d_fz, d_fx_old, d_fy_old, d_fz_old);
		gpu_Leonard_Jones << <grid_size, block_size >> > (n, sigma, epsilon, m, r_cut2, U_shift, L, d_x, d_y, d_z,
			d_fx, d_fy, d_fz, d_U);
		integrate_velocities << <grid_size, block_size >> > (n, m, L, dt, d_vx, d_vy, d_vz, d_fx, d_fy, d_fz,
			d_fx_old, d_fy_old, d_fz_old);
		if (i % 1000 == 0) {
			cudaDeviceSynchronize();
			cudaMemcpy(&U, d_U, sizeof(double), cudaMemcpyDeviceToHost);
			cudaMemcpy(vx, d_vx, size, cudaMemcpyDeviceToHost);
			cudaMemcpy(vy, d_vy, size, cudaMemcpyDeviceToHost);
			cudaMemcpy(vz, d_vz, size, cudaMemcpyDeviceToHost);
			double K = kinetic_energy(n, m, vx, vy, vz);
			double T = temperature(n, m, vx, vy, vz);
			double E = K + U;

			std::cout << "Total energy:" << E << " ";
			std::cout << "Kinetic energy:" << K << " ";
			std::cout << "Potential energy:" << U << " ";
			std::cout << "Temperature:" << T << " ";
			std::cout << std::endl;
		}

	}


