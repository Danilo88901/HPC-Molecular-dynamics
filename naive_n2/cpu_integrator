#include <cmath>
#include "md.h"
double integrate(int n, double sigma, double epsilon, double m, double dt, double r_cut2,
	double U_shift, double L, double* x,
	double* y, double* z, double* fx, double* fy, double* fz,
	double* vx, double* vy, double* vz, double* fx_old, double* fy_old, double* fz_old) {
	for (int i = 0; i < n; i++) {
		fx_old[i] = fx[i];
		fy_old[i] = fy[i];
		fz_old[i] = fz[i];
	}

	for (int i = 0; i < n; i++) {
		x[i] += dt * vx[i] + 0.5 * fx[i] / m * dt * dt;
		x[i] -= L * std::round(x[i] / L);

		y[i] += dt * vy[i] + 0.5 * fy[i] / m * dt * dt;
		y[i] -= L * std::round(y[i] / L);

		z[i] += dt * vz[i] + 0.5 * fz[i] / m * dt * dt;
		z[i] -= L * std::round(z[i] / L);
	}
	double U = Lennard_Jones(n, sigma, epsilon, m, r_cut2, U_shift, L, x, y, z, fx, fy, fz);

	for (int i = 0; i < n; i++) {
		vx[i] += 0.5 * (fx[i] + fx_old[i]) / m * dt;
		vy[i] += 0.5 * (fy[i] + fy_old[i]) / m * dt;
		vz[i] += 0.5 * (fz[i] + fz_old[i]) / m * dt;
	}
	return U;
}
